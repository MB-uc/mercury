{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mercury.idx.inc/schemas/artefact.schema.json",
  "title": "Mercury Stage Artefact",
  "description": "The structured output of a Mercury pipeline stage. Source of truth for downstream stages and rendering.",
  "type": "object",
  "required": [
    "stage",
    "entity",
    "domain",
    "claims",
    "findings"
  ],
  "properties": {
    "company": {
      "type": "string",
      "description": "Legacy field. Use 'entity' for new artefacts."
    },
    "entity": {
      "type": "string",
      "minLength": 1,
      "description": "Company or peer under analysis."
    },
    "domain": {
      "type": "string",
      "minLength": 1,
      "description": "Primary website domain."
    },
    "stage": {
      "type": "string",
      "enum": ["brief", "compete", "sitemap", "meeting"],
      "description": "Pipeline stage that produced this artefact."
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of artefact generation."
    },
    "scope": {
      "type": "object",
      "properties": {
        "focus": { "type": "string" },
        "confirmed_at": { "type": "string" }
      }
    },
    "capabilities_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "executive_summary": {
      "type": "string"
    },
    "claims": {
      "type": "array",
      "items": { "$ref": "claim.schema.json" },
      "description": "Atomic claims built before findings. The bounded knowledge layer."
    },
    "claim_builder_errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["error_id", "candidate_statement", "rejection_reason"],
        "properties": {
          "error_id": { "type": "string", "pattern": "^CBE-[0-9]{3,}$" },
          "candidate_statement": { "type": "string" },
          "candidate_scope": { "type": "string" },
          "rejection_reason": {
            "type": "string",
            "enum": [
              "missing_required_field",
              "invalid_certainty",
              "invalid_claim_type",
              "invalid_method",
              "missing_evidence_linkage",
              "unsupported_site_wide_claim",
              "unbounded_negative_claim",
              "legacy_artefact_derivation"
            ]
          },
          "evidence_ids": { "type": "array", "items": { "type": "string" } },
          "detail": { "type": "string" },
          "suggested_revision": { "type": "string" },
          "suggested_scope": { "type": "string" }
        }
      },
      "description": "Claims rejected at construction time."
    },
    "evidence_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_id"],
        "properties": {
          "evidence_id": { "type": "string", "pattern": "^E-[0-9]{3,}$" },
          "source_url": { "type": "string" },
          "evidence_area": { "type": "string" },
          "section": { "type": "string" },
          "collection_method": { "type": "string" }
        }
      },
      "description": "Evidence items with area metadata for site-wide claim validation."
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "claim_ids"],
        "properties": {
          "id": { "type": "string", "pattern": "^F-[0-9]{3,}$" },
          "classification": { "type": "string", "enum": ["FACT", "INFERENCE", "JUDGEMENT"] },
          "claim": { "type": "string" },
          "claim_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^C-(L?)[0-9]{3,}$" }
          },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "citations": { "type": "array", "items": { "type": "integer" } },
          "confidence": { "type": "string" },
          "reasoning": { "type": "string" },
          "evidence_basis": { "type": "array", "items": { "type": "string" } },
          "severity": { "type": "string" },
          "polarity": { "type": "string", "enum": ["positive", "negative", "mixed"] },
          "section": { "type": "string" }
        }
      }
    },
    "gap_analysis": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": { "type": "string" },
          "status": { "type": "string" },
          "detail": { "type": "string" },
          "search_method": { "type": "string" },
          "claim_ids": { "type": "array", "items": { "type": "string" } },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "citations": { "type": "array", "items": { "type": "integer" } }
        }
      }
    },
    "synthesis": {
      "type": "object",
      "properties": {
        "overall_assessment": { "type": "string" },
        "priorities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["claim_ids"],
            "properties": {
              "priority": { "type": "integer" },
              "recommendation": { "type": "string" },
              "rationale": { "type": "string" },
              "claim_ids": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "pattern": "^C-(L?)[0-9]{3,}$" }
              },
              "effort": { "type": "string" },
              "impact": { "type": "string" }
            }
          }
        }
      }
    },
    "rendered_units": {
      "type": "array",
      "items": { "$ref": "rendered_unit.schema.json" },
      "description": "Discrete narrative chunks validated before final markdown assembly."
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ref": { "type": "integer" },
          "type": { "type": "string" },
          "source": { "type": "string" },
          "accessed": { "type": "string" },
          "claims_supported": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "protocol_interventions": {
      "type": "array",
      "items": { "$ref": "intervention.schema.json" },
      "description": "Diagnostic log of governance protocol interventions. Optional — artefacts without this field remain valid."
    },
    "compliance": {
      "type": "object",
      "properties": {
        "checks_passed": { "type": "integer" },
        "checks_failed": { "type": "integer" },
        "failures": { "type": "array" },
        "repairs": { "type": "array" }
      }
    }
  },
  "additionalProperties": true
}
